{
    "sandbox": {
        "enabled": true,
        "failIfUnavailable": true,
        "autoAllowBashIfSandboxed": true,
        "allowUnsandboxedCommands": false,
        "enableWeakerNetworkIsolation": true,
        "enableWeakerNestedSandbox": true,
        "excludedCommands": [
            "git ",
            "gh ",
            "docker ",
            "npm ",
            "npx ",
            "pnpm ",
            "node ",
            "python3 ",
            "python ",
            "pip ",
            "pip3 "
        ],
        "filesystem": {
            "denyRead": [
                "~/.ssh",
                "~/.gnupg",
                "~/.aws",
                "~/.kube",
                "~/.npmrc",
                "~/.netrc",
                "~/.pypirc",
                "~/.docker/config.json",
                "~/.config/gcloud",
                "~/.aws/credentials"
            ],
            "denyWrite": [
                "~/.ssh",
                "~/.gnupg",
                "~/.aws",
                "~/.kube"
            ],
            "allowWrite": [
                "~/.npm",
                "~/.cache/pnpm",
                "~/.cache/pip",
                "~/.cargo/registry",
                "/tmp/build"
            ]
        },
        "network": {
            "allowAllUnixSockets": true,
            "allowLocalBinding": true,
            "allowedDomains": [
                "registry.npmjs.org",
                "*.npmjs.org",
                "github.com",
                "*.github.com",
                "api.github.com",
                "raw.githubusercontent.com",
                "objects.githubusercontent.com",
                "pypi.org",
                "*.pypi.org",
                "files.pythonhosted.org",
                "crates.io",
                "*.crates.io",
                "index.crates.io",
                "proxy.golang.org",
                "sum.golang.org",
                "goproxy.io",
                "hub.docker.com",
                "*.docker.io",
                "*.docker.com",
                "productionresultssa8.blob.core.windows.net",
                "productionresultssa13.blob.core.windows.net",
                "productionresultssa19.blob.core.windows.net",
                "results-receiver.actions.githubusercontent.com",
                "*.fangzuquan.tk",
                "fangzuquan.tk",
                "*.ynight.tk",
                "ynight.tk",
                "gitee.com",
                "cafe.github.com"
            ]
        }
    },
    "disableBypassPermissionsMode": "disable",
    "permissions": {
        "allow": ["WebFetch"],
        "deny": [
            "Bash(sudo *)",
            "Bash(rm -rf /)",
            "Bash(rm -rf ~)",
            "Bash(rm -rf /*)",
            "Bash(chmod 777 *)",
            "Bash(chmod -R 777 *)",
            "Bash(chown *)",
            "Bash(mkfs *)",
            "Bash(dd *)",
            "Bash(chattr *)",
            "Bash(> /dev/sda*)",
            "Bash(mv /* /dev/null *)",
            "Bash(wget * | sh)",
            "Bash(curl * | sh)",
            "Bash(curl * | bash)",
            "Bash(wget * | bash)",
            "Bash(nc -l *)",
            "Bash(ncat *)",
            "Read(~/.ssh/**)",
            "Read(~/.gnupg/**)",
            "Read(~/.aws/**)",
            "Read(~/.kube/**)",
            "Read(~/.npmrc)",
            "Read(~/.netrc)",
            "Read(~/.pypirc)",
            "Read(~/.docker/config.json)",
            "Read(~/.config/gcloud/**)",
            "Read(./**/*.pem)",
            "Read(./**/*.key)",
            "Read(./**/*.p12)",
            "Read(./**/*.pfx)",
            "Read(./**/id_rsa*)",
            "Read(./**/id_ed25519*)",
            "Read(./**/.env)",
            "Read(./credentials*)",
            "Read(./secrets/**)",
            "Read(./**/terraform.tfstate*)",
            "Read(./**/*.tfvars)"
        ]
    }
}